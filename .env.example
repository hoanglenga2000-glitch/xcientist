# Non-secret runtime settings and references only. Store provider credentials
# with `evomind setup`, or point *_FILE variables at protected files outside
# the repository. EvoMind never creates or loads a root .env file.
ANTHROPIC_API_KEY_FILE=
ANTHROPIC_BASE_URL=https://api.anthropic.com
CLAUDE_CODE_MODEL=sonnet

DEEPSEEK_API_KEY_FILE=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OPENAI_API_KEY_FILE=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5

# Evolution engine LLM routing: which provider leads, which is fallback.
EVOLUTION_PRIMARY_PROVIDER=anthropic
EVOLUTION_FALLBACK_PROVIDER=deepseek

GPU_SSH_HOST=
GPU_SSH_PORT=22
GPU_SSH_USER=
GPU_SSH_PASSWORD_FILE=
GPU_SSH_KEY_PATH=
GPU_SSH_KEY_PATH_FILE=
GPU_SSH_KNOWN_HOSTS_PATH=
GPU_SSH_KNOWN_HOSTS_PATH_FILE=
GPU_SSH_SOCKS_HOST=
GPU_SSH_SOCKS_PORT=1080
GPU_SSH_SOCKS_USER=
GPU_SSH_SOCKS_USER_FILE=
GPU_SSH_SOCKS_PASSWORD_FILE=
GPU_REMOTE_WORKSPACE=
WORKSTATION_SECRET_DIR=

KAGGLE_USERNAME_FILE=
KAGGLE_KEY_FILE=

# Inject production DATABASE_URL through the service environment or secret
# manager. Do not persist database credentials in a project .env file.
