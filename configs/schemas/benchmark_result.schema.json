{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-os.local/schemas/benchmark_result.schema.json",
  "title": "BenchmarkResult",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "task_id",
    "best_exp_id",
    "best_cv_score",
    "best_public_score",
    "best_private_score",
    "valid_submission",
    "medal",
    "rank_percentile",
    "runtime_hours",
    "num_experiments",
    "num_failed_runs",
    "num_recoveries",
    "reproducibility_score",
    "auditability_score",
    "claim_drift_detected",
    "final_report_path",
    "artifacts_path",
    "gap_to_mlevolve",
    "next_improvement_plan"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "best_exp_id": { "type": ["string", "null"] },
    "best_cv_score": { "type": ["number", "null"] },
    "best_public_score": { "type": ["number", "null"] },
    "best_private_score": { "type": ["number", "null"] },
    "valid_submission": { "type": "boolean" },
    "medal": { "type": "string", "enum": ["none", "bronze", "silver", "gold", "unknown"] },
    "rank_percentile": { "type": ["number", "null"] },
    "runtime_hours": { "type": "number" },
    "num_experiments": { "type": "integer" },
    "num_failed_runs": { "type": "integer" },
    "num_recoveries": { "type": "integer" },
    "reproducibility_score": { "type": "number" },
    "auditability_score": { "type": "number" },
    "claim_drift_detected": { "type": "boolean" },
    "final_report_path": { "type": ["string", "null"] },
    "artifacts_path": { "type": ["string", "null"] },
    "gap_to_mlevolve": { "type": ["string", "number", "null"] },
    "next_improvement_plan": { "type": "string" },
    "top30_reached": { "type": "boolean", "default": false },
    "official_rank": { "type": ["integer", "null"] },
    "leaderboard_team_count": { "type": ["integer", "null"] },
    "official_submission_ref": { "type": ["string", "null"] },
    "mlebench_comparable": { "type": "boolean", "default": false },
    "overclaim_risk": { "type": "string" }
  }
}
