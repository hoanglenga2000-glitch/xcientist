{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-os.local/schemas/retrospective_memory.schema.json",
  "title": "RetrospectiveMemoryRecord",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "memory_id",
    "task_type",
    "dataset_profile",
    "method",
    "what_worked",
    "what_failed",
    "metric_delta",
    "reusable_strategy",
    "failure_pattern",
    "linked_exp_ids"
  ],
  "properties": {
    "memory_id": { "type": "string" },
    "task_type": { "type": "string" },
    "dataset_profile": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean", "null", "array", "object"] }
    },
    "method": { "type": "string" },
    "what_worked": { "type": "string" },
    "what_failed": { "type": "string" },
    "metric_delta": { "type": ["number", "null"] },
    "reusable_strategy": { "type": "string" },
    "failure_pattern": { "type": "string" },
    "linked_exp_ids": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
