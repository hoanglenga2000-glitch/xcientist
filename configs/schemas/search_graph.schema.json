{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-os.local/schemas/search_graph.schema.json",
  "title": "SearchGraph",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "task_id",
    "root_exp_id",
    "nodes",
    "edges",
    "top_candidates",
    "stagnation_branches",
    "selected_next_branch",
    "exploration_stage"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "root_exp_id": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": { "$ref": "experiment_node.schema.json" }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target"],
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "reference_edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "source": { "type": "string" },
          "target": { "type": "string" },
          "reason": { "type": "string" },
          "reference_type": { "type": "string" },
          "reusable_strategy": { "type": "string" }
        }
      }
    },
    "top_candidates": {
      "type": "array",
      "items": { "type": "string" }
    },
    "branch_diverse_top_candidates": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stagnation_branches": {
      "type": "array",
      "items": { "type": "string" }
    },
    "global_stagnation": { "type": "boolean" },
    "selected_next_branch": { "type": ["string", "null"] },
    "exploration_stage": {
      "type": "string",
      "enum": ["exploration", "transition", "exploitation"]
    }
  }
}
