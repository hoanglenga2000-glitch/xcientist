import { NextResponse } from "next/server";
import { runEnsembleExperiment } from "@/lib/server/runs";

export const dynamic = "force-dynamic";

export async function POST(_request: Request, { params }: { params: { taskId: string } }) {
  try {
    return NextResponse.json(await runEnsembleExperiment(params.taskId));
  } catch (error) {
    const message = error instanceof Error ? error.message : "Unknown ensemble run error";
    return NextResponse.json({ ok: false, task_id: params.taskId, error: message }, { status: 500 });
  }
}
