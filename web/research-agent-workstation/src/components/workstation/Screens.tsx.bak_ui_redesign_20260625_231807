export function CodeRunner(props: ScreenProps) {
  const runtime = runtimeForTask(props.summary, props.selectedTask);
  const [draft, setDraft] = useState<Awaited<ReturnType<typeof api.generateCodeAgentDraft>> | null>(null);
  const [busy, setBusy] = useState<string | null>(null);
  const taskId = normalizeTaskId(props.selectedTask);
  async function runDraft(sourceAgent: string) {
    setBusy(sourceAgent);
    try {
      const payload = await api.generateCodeAgentDraft(taskId, { source_agent: sourceAgent });
      setDraft(payload);
    } finally {
      setBusy(null);
    }
  }

  const generatedCode = draft?.generated_code || String(runtime?.generated_code ?? "");
  const patchDiff = draft?.patch_diff || "";

  return (
    <StandardPage title={tx(props.locale, "Code Agent Workspace", "代码 Agent 工作区")} description={tx(props.locale, "Code is drafted by configured agents and must pass review gates before execution.", "DeepSeek / Claude Code 只负责起草；应用、HPC 执行和提交必须经过工作站 Gate。")} {...props}>
      <ScoreRecoveryCard runtime={runtime} />
      <div className="grid gap-4 xl:grid-cols-[280px_1fr_320px] items-start">
        {/* Left: Actions */}
        <WorkbenchSection title="Code Agent Actions" description="Trigger draft and patch workflows.">
          <div className="flex flex-col gap-2">
            <Button size="sm" onClick={() => props.exportCodeAgentContext?.(taskId, "claude_code")}>Export Claude Context</Button>
            <Button size="sm" variant="secondary" onClick={() => runDraft("deepseek_code_agent")} disabled={Boolean(busy)}>{busy === 'deepseek_code_agent' ? "Generating..." : "DeepSeek Draft"}</Button>
            <Button size="sm" variant="secondary" onClick={() => runDraft("claude_code")} disabled={Boolean(busy)}>{busy === 'claude_code' ? "Generating..." : "Claude Code Draft"}</Button>
            <Button size="sm" variant="secondary" onClick={() => props.importDemoPatch?.(taskId)}>Import Demo Patch</Button>
            <hr className="my-2 border-slate-200" />
            <Button size="sm" variant="secondary" onClick={() => props.runWorkstationAction?.("review_agent_patch")}>Review Latest Patch</Button>
            <Button size="sm" className="bg-primary text-white" onClick={() => props.runWorkstationAction?.("apply_agent_patch")}>Apply Patch</Button>
            <div className="text-[10px] text-amber-600 mt-1">Requires Code Quality Gate</div>
            <Button size="sm" variant="danger" onClick={() => props.runWorkstationAction?.("rollback_agent_patch")}>Rollback Patch</Button>
          </div>
        </WorkbenchSection>
        
        {/* Middle: Code */}
        <WorkbenchSection title="Generated Code & Patch" description="Review drafted changes before applying.">
           {generatedCode || patchDiff ? (
             <div className="space-y-4">
               {generatedCode && (
                 <div>
                   <div className="text-sm font-bold text-slate-700 mb-2">Generated Code</div>
                   <CodeBlockPanel code={generatedCode} />
                 </div>
               )}
               {patchDiff && (
                 <div>
                   <div className="text-sm font-bold text-slate-700 mb-2">Patch Diff</div>
                   <CodeBlockPanel code={patchDiff} />
                 </div>
               )}
             </div>
           ) : (
             <RealEmptyState message="No generated code or patch artifact loaded. Use the actions on the left to generate one." />
           )}
        </WorkbenchSection>

        {/* Right: Info */}
        <WorkbenchSection title="Session & Artifacts" description="Current code agent state.">
          <ArtifactPathRow label="Draft Path" path={draft?.draft_path ?? runtime?.latest_code_agent_session?.draft_path as string | null} />
          <ArtifactPathRow label="Patch Path" path={draft?.patch_path ?? runtime?.latest_code_agent_review?.patch_path as string | null} />
          <ArtifactPathRow label="Manifest Path" path={draft?.manifest_path ?? runtime?.latest_code_agent_session?.manifest_path as string | null} />
          <ArtifactPathRow label="Transcript Path" path={draft?.transcript_path ?? runtime?.latest_code_agent_transcript?.path as string | null} />
          
          <div className="mt-4">
            <div className="text-xs font-bold text-slate-700 mb-2">Latest Action Trace</div>
            <ActionTrace trace={props.lastActionTrace} message={props.agentActionMessage} />
          </div>
          
          <div className="mt-4">
            <div className="text-xs font-bold text-slate-700 mb-2">Quality Gate Status</div>
            <StatusBadge tone={draft?.configured === false ? "amber" : draft ? "green" : "slate"}>
              {draft?.cli_status ?? (runtime?.generated_code ? "loaded" : "empty")}
            </StatusBadge>
          </div>
          
          {draft?.missing_env && draft.missing_env.length > 0 && (
            <div className="mt-4">
               <div className="text-xs font-bold text-red-700 mb-2">Missing Env (Do not show values)</div>
               <ul className="text-xs text-slate-600 list-disc pl-4">
                 {draft.missing_env.map(env => <li key={env}>{env}</li>)}
               </ul>
            </div>
          )}
        </WorkbenchSection>
      </div>
    </StandardPage>
  );
}

