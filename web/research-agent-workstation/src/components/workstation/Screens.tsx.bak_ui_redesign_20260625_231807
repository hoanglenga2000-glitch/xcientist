function ScoreRecoveryCard({ runtime }: { runtime?: RuntimePayload }) {
  const gate = pickRecord(runtime?.score_improvement_gate);
  const recovery = pickRecord(runtime?.score_regression_recovery_plan ?? runtime?.score_regression_diagnosis);
  const failed = pickRecord(recovery.failed_candidate ?? recovery.score_summary);
  const rollback = pickRecord(recovery.rollback_baseline);
  const status = String(recovery.status ?? gate.status ?? "pending");
  const blockedReasons = Array.isArray(gate.blocked_reasons)
    ? gate.blocked_reasons.map(String)
    : Array.isArray(recovery.hard_blocks_for_next_run)
      ? recovery.hard_blocks_for_next_run.map(String)
      : [];
  const workOrder = Array.isArray(recovery.next_agent_work_order)
    ? recovery.next_agent_work_order as Array<Record<string, unknown>>
    : Array.isArray(pickRecord(recovery.next_agent_work_order).agents)
      ? pickRecord(recovery.next_agent_work_order).agents as Array<Record<string, unknown>>
      : [];

  return (
    <Card>
      <CardHeader className="flex flex-row items-start justify-between gap-3">
        <div>
          <CardTitle>Score Regression Recovery</CardTitle>
          <CardDescription>Low-score candidates are blocked and returned to responsible agents.</CardDescription>
        </div>
        <StatusBadge tone={scoreTone(status)}>{status.replaceAll("_", " ")}</StatusBadge>
      </CardHeader>
      <CardContent className="space-y-4">
        <div className="grid gap-3 md:grid-cols-4">
          <MetricTile label="Current score" value={failed.public_score ?? failed.candidate_validation_score ?? gate.current_public_score} tone={scoreTone(status)} />
          <MetricTile label="Protected best" value={rollback.public_score ?? gate.historical_best_public_score ?? "0.96659"} tone="green" />
          <MetricTile label="Validation floor" value={gate.minimum_candidate_validation_score ?? rollback.validation_balanced_accuracy} tone="green" />
          <MetricTile label="Submit allowed" value={String(gate.status === "passed")} tone={gate.status === "passed" ? "green" : "red"} />
        </div>
        <div className="rounded-md border border-red-100 bg-red-50 p-3 text-xs text-red-900">
          <div className="font-bold">Why this matters</div>
          <div className="mt-2 space-y-1">
            {(blockedReasons.length ? blockedReasons : ["Score gate must prove the candidate beats the protected baseline before official submit."]).slice(0, 5).map((item) => (
              <div key={item}>- {item}</div>
            ))}
          </div>
        </div>
        <div className="grid gap-3 lg:grid-cols-2">
          <div className="rounded-md border border-blue-100 bg-blue-50 p-3 text-xs">
            <div className="font-bold text-blue-900">Next Agent Work Order</div>
            <div className="mt-2 space-y-2">
              {(workOrder.length ? workOrder : [
                { agent_id: "ModelSelectionAgent", instruction: "Return to the EXP007 probability-blend baseline." },
                { agent_id: "CodeImplementationAgent", instruction: "Generate reviewable code only." },
                { agent_id: "ValidationAnalysisAgent", instruction: "Compare against protected best before submission." }
              ]).slice(0, 5).map((agent) => (
                <div key={String(agent.agent_id)} className="rounded bg-white px-2 py-2">
                  <div className="font-bold text-slate-900">{String(agent.agent_id)}</div>
                  <div className="mt-1 text-slate-600">{String(agent.instruction ?? agent.required_output ?? "artifact required")}</div>
                </div>
              ))}
            </div>
          </div>
          <div className="rounded-md border border-slate-200 bg-slate-50 p-3 text-xs">
            <div className="font-bold text-slate-900">Rollback Baseline Contract</div>
            <Row label="Experiment" value={rollback.experiment_id ?? "EXP007"} />
            <Row label="Policy" value={rollback.policy ?? "preserve_as_safe_submission_baseline"} />
            <Row label="Artifact" value={recovery.artifact_path ?? "score_regression_recovery_plan.json"} />
          </div>
        </div>
      </CardContent>
    </Card>
  );
}

