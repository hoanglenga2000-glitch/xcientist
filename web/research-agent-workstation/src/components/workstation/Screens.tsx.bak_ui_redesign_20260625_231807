  setLocale?: (locale: Locale) => void;
};

function tx(locale: Locale | undefined, en: string, zh: string) {
  return locale === "zh-CN" ? zh : en;
}

function normalizeTaskId(taskId?: string) {
  const value = taskId || "playground_series_s6e6";
  return value === "house-prices" ? "house_prices" : value;
}

function runtimeForTask(summary: WorkstationSummary | null | undefined, taskId?: string): RuntimePayload | undefined {
  const normalized = normalizeTaskId(taskId);
  return (summary?.runtime_by_task?.[normalized] ?? summary?.runtime) as RuntimePayload | undefined;
}

function latestRunForTask(summary: WorkstationSummary | null | undefined, taskId?: string): SummaryRun | undefined {
  const normalized = normalizeTaskId(taskId);
  return summary?.runs?.find((run) => normalizeTaskId(run.task_id) === normalized) ?? summary?.runs?.[0];
}

function connectorEntry(summary: WorkstationSummary | null | undefined, key: string) {
  return (summary?.connector_status as Record<string, any> | undefined)?.[key] as Record<string, any> | undefined;
}

function pickRecord(value: unknown): Record<string, unknown> {
  return value && typeof value === "object" && !Array.isArray(value) ? value as Record<string, unknown> : {};
}

function scoreTone(status?: unknown): StatusTone {
  const value = String(status ?? "").toLowerCase();
  if (value.includes("passed") || value.includes("ready") || value.includes("verified") || value.includes("complete")) return "green";
  if (value.includes("blocked") || value.includes("failed") || value.includes("regression")) return "red";
  if (value.includes("running") || value.includes("submitted")) return "blue";
  return "amber";
}

function connectorDisplay(entry: Record<string, any> | undefined) {
  const configured = Boolean(entry?.configured);
  const state = String(entry?.state ?? (configured ? "ready" : "not configured"));
  const normalized = state.toLowerCase();
  const verified = normalized.includes("verified")
    || normalized.includes("ready")
    || normalized.includes("passed")
    || Boolean(entry?.evidence?.latest_ssh_connection?.passed)
    || Boolean(entry?.toolchain_ready);

  if (configured && verified) return { state, tone: "green" as StatusTone, label: "ready" };
  if (configured) return { state, tone: "blue" as StatusTone, label: "configured" };
  if (verified) return { state, tone: "amber" as StatusTone, label: "evidence only" };
  return { state, tone: "red" as StatusTone, label: "not configured" };
}

function valueText(value: unknown, fallback = "n/a") {
  if (typeof value === "number") return Number.isFinite(value) ? value.toFixed(6) : fallback;
  if (typeof value === "string" && value.length) return value;
  if (typeof value === "boolean") return value ? "true" : "false";
  return fallback;
}

