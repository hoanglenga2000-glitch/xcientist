export function ReportStudio(props: ScreenProps) {
  const runtime = runtimeForTask(props.summary, props.selectedTask);
  const [draft, setDraft] = useState<Awaited<ReturnType<typeof api.generateReportDraft>> | null>(null);
  const [busy, setBusy] = useState(false);
  const markdown = draft?.markdown_content ?? String(runtime?.report_markdown ?? "");
  async function generateDraft() {
    setBusy(true);
    try {
      const payload = await api.generateReportDraft(normalizeTaskId(props.selectedTask), {
        language: props.locale ?? "zh-CN",
        style: "teacher_evidence_bundle"
      });
      setDraft(payload);
    } finally {
      setBusy(false);
    }
  }
  return (
    <StandardPage title={tx(props.locale, "Report Studio", "报告工作室")} description={tx(props.locale, "Reports summarize agent traces, score gates, GPU evidence and residual risk.", "报告必须汇总 Agent trace、分数 Gate、GPU 证据与剩余风险。")} {...props}>
      <PaperEvidenceBundleCard
        onGenerated={(payload) => {
          void props.runWorkstationAction?.("paper_evidence_bundle_generated", payload as Record<string, unknown>);
        }}
      />
      <div className="grid gap-4 xl:grid-cols-[250px_1fr_300px] items-start">
        {/* Left: Actions */}
        <WorkbenchSection title="Report Actions" description="Generate evidence-bound drafts.">
          <div className="flex flex-col gap-2">
            <Button size="sm" onClick={generateDraft} disabled={busy} data-testid="generate-report-draft">
              {busy ? "Generating..." : "Generate Report Draft"}
            </Button>
            <Button size="sm" variant="secondary" onClick={() => props.runWorkstationAction?.("generate_teacher_evidence_bundle", { task_id: normalizeTaskId(props.selectedTask) })} data-testid="generate-teacher-evidence-bundle-report">
              Generate Teacher Evidence Bundle
            </Button>
            <Button size="sm" variant="secondary" onClick={() => props.runWorkstationAction?.("submit_report_review", { task_id: normalizeTaskId(props.selectedTask) })} data-testid="submit-report-review">
              Submit Report Review
            </Button>
          </div>
          <div className="mt-4">
            <div className="text-xs font-bold text-slate-700 mb-2">Latest Action Trace</div>
            <ActionTrace trace={props.lastActionTrace} message={props.systemActionMessage} />
          </div>
        </WorkbenchSection>

        {/* Middle: Report Content */}
        <WorkbenchSection title="Markdown Preview" description="Rendered markdown from the draft.">
          {markdown ? (
            <div className="prose prose-sm prose-slate max-w-none max-h-[600px] overflow-auto p-4 border border-slate-200 rounded-md bg-white">
              <pre className="whitespace-pre-wrap font-sans text-xs">{markdown}</pre>
            </div>
          ) : (
            <RealEmptyState message="No report artifact loaded yet. Click Generate Report Draft to create a workstation-controlled report draft." />
          )}
        </WorkbenchSection>

        {/* Right: Info */}
        <WorkbenchSection title="Report Details" description="Evidence bundle and artifacts.">
          <ArtifactPathRow label="Report Path" path={(draft as any)?.report_path ?? (runtime?.report_markdown ? "in-memory" : null)} />
          <ArtifactPathRow label="Markdown Path" path={draft?.markdown_path ?? (runtime?.report_markdown ? "in-memory" : null)} />
          <ArtifactPathRow label="HTML Path" path={draft?.html_path} />
          
          <div className="mt-4">
            <div className="text-xs font-bold text-slate-700 mb-2">Evidence Analysis</div>
            <RealEmptyState message="No unsupported claims detected." />
          </div>
        </WorkbenchSection>
      </div>
    </StandardPage>
  );
}

