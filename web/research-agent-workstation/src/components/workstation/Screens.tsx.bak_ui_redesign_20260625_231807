}

function MetricTile({ label, value, tone = "slate" }: { label: string; value: unknown; tone?: StatusTone }) {
  return (
    <div className="rounded-md border border-slate-200 bg-white p-3">
      <div className="text-[11px] font-bold uppercase text-slate-500">{label}</div>
      <div className="mt-1 truncate text-lg font-bold text-slate-950">{valueText(value)}</div>
      <StatusBadge tone={tone} className="mt-2">{tone}</StatusBadge>
    </div>
  );
}

function StandardPage({
  title,
  description,
  children,
  summary,
  selectedTask
}: {
  title: string;
  description: string;
  children?: React.ReactNode;
  summary?: WorkstationSummary | null;
  selectedTask?: string;
}) {
  const runtime = runtimeForTask(summary, selectedTask);
  const latestRun = latestRunForTask(summary, selectedTask);
  const scoreStatus = String(
    runtime?.score_regression_recovery_plan?.status
    ?? runtime?.score_regression_diagnosis?.status
    ?? runtime?.score_improvement_gate?.status
    ?? "pending"
  );
  return (
    <main className="space-y-4">
      {sectionTitle(title, description)}
      <div className="grid gap-3 md:grid-cols-4">
        <MetricTile label="Run" value={latestRun?.id ?? "pending"} tone={scoreTone(latestRun?.status)} />
        <MetricTile label="Run Status" value={latestRun?.status ?? "ready"} tone={scoreTone(latestRun?.status)} />
        <MetricTile label="Score Gate" value={scoreStatus} tone={scoreTone(scoreStatus)} />
        <MetricTile label="Artifacts" value={summary?.evidence?.length ?? 0} tone={(summary?.evidence?.length ?? 0) ? "green" : "amber"} />
      </div>
      {children}
    </main>
  );
}

