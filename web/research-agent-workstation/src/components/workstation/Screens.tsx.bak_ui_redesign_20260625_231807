export function GpuHpcConsole(props: ScreenProps) {
  const [gpuStatus, setGpuStatus] = useState<GpuGatewayResponse | null>(null);
  async function testGpu() {
    const payload = await api.testGpuConnection();
    setGpuStatus(payload);
    await props.runWorkstationAction?.("gpu_connection_test", payload as unknown as Record<string, unknown>);
  }
  async function submitProbe(template = "playground_s6e6_boosting_ensemble") {
    const latestRun = latestRunForTask(props.summary, props.selectedTask);
    const runId = latestRun?.id ?? "wr_s6e6_gate_probe";
    const payload = await api.submitGpuJob(normalizeTaskId(props.selectedTask), template, {
      run_id: runId,
      agent_id: "HpcGpuExecutionAgent",
      gate_id: `${runId}_hpc_execution_approval`,
      resource_request: { mode: "s6e6_score_recovery", template }
    });
    setGpuStatus(payload);
    await props.runWorkstationAction?.("gpu_job_submit", payload as unknown as Record<string, unknown>);
  }
  return (
    <StandardPage title={tx(props.locale, "GPU / HPC Console", "GPU / HPC 控制台")} description={tx(props.locale, "GPU jobs can run only through workstation whitelist templates and gates.", "GPU 作业只能通过工作站白名单模板和 Gate 启动。")} {...props}>
      <ResourceCard summary={props.summary} />
      <Card>
        <CardHeader>
          <CardTitle>Gateway Actions</CardTitle>
          <CardDescription>Use smoke checks for connectivity; long training remains manifest-gated.</CardDescription>
        </CardHeader>
        <CardContent className="space-y-3">
          <div className="flex flex-wrap gap-2">
            <Button onClick={testGpu} data-testid="test-gpu-connection"><Activity className="h-4 w-4" />Test GPU</Button>
            <Button variant="primary" onClick={() => submitProbe()} data-testid="submit-score-gated-gpu-job"><Play className="h-4 w-4" />Probe Score-Gated Job</Button>
          </div>
          <Row label="Status" value={gpuStatus?.status ?? "not run in this browser"} />
          <Row label="Provider" value={gpuStatus?.provider ?? "ssh_gateway"} />
          <Row label="Artifact" value={gpuStatus?.artifact_path ?? "n/a"} />
        </CardContent>
      </Card>
    </StandardPage>
  );
}

